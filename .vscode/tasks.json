{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "esbuild: build",
      "type": "shell",
      "command": "node esbuild.mjs",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "esbuild: watch",
      "type": "shell",
      "command": "node esbuild.mjs --watch",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "tsc: check types",
      "type": "shell",
      "command": "npx tsc --noEmit",
      "group": "build",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
